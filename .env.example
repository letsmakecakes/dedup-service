# =============================================================================
# dedup-service environment variables
# Copy to .env and adjust. All variables have the defaults shown here.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
DEDUP_LISTEN_ADDR=:8081
DEDUP_LOG_LEVEL=info                  # debug | info | warn | error
DEDUP_SHUTDOWN_TIMEOUT=10s

# ── Redis ─────────────────────────────────────────────────────────────────────
DEDUP_REDIS_ADDR=localhost:6379
DEDUP_REDIS_PASSWORD=
DEDUP_REDIS_DB=0
DEDUP_REDIS_DIAL_TIMEOUT=2s
DEDUP_REDIS_READ_TIMEOUT=200ms
DEDUP_REDIS_WRITE_TIMEOUT=200ms
DEDUP_REDIS_POOL_SIZE=100
DEDUP_REDIS_MIN_IDLE=20

# ── Deduplication ─────────────────────────────────────────────────────────────
DEDUP_WINDOW=10s                      # Redis TTL for fingerprint keys
DEDUP_MAX_BODY_BYTES=65536            # max body bytes hashed (64 KB)
DEDUP_FAIL_OPEN=true                  # true = allow requests if Redis is down
DEDUP_EXCLUDE_METHODS=GET,HEAD,OPTIONS

# Fingerprint: SHA-256( Method | URI+Query | Body )
# No identity signal (Authorization, session, client IP) is used.
# Uniqueness across callers is guaranteed by request content (resource IDs, etc.)

# ── Proxy / X-Accel-Redirect mode ─────────────────────────────────────────────
# X-Accel-Redirect mode (recommended): Nginx sends the full request (with body)
# to the dedup service. The service returns X-Accel-Redirect for allowed requests
# and 409 for duplicates. Nginx then internally redirects to the upstream.
DEDUP_PROXY_X_ACCEL_REDIRECT_PREFIX=  # e.g. /internal/upstream

# Reverse-proxy mode: the Go service itself proxies allowed requests to upstream.
# Nginx simply forwards all traffic to the Go service.
DEDUP_PROXY_UPSTREAM_URL=             # e.g. http://backend:8000
